# Local-only scratch — reference material, image snapshots, planning notes,
# anything we keep on the machine but don't want tracked.
.local/
docs/

# Sibling ComfyUI plugins developed alongside the studio. Each subfolder is its
# own git repo and is published separately to ComfyRegistry / GitHub.
plugins/

# Dependencies — reinstalled per-environment from the lockfile.
node_modules/

# Build output — regenerated by `npm run build` / `vite build` / `tsc`.
dist/
build/
*.tsbuildinfo

# Editor / OS detritus.
.vscode/
.idea/
.DS_Store
Thumbs.db
.claude/

# Secrets / env — never commit.
.env
.env.*
!.env.example

# Logs.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / test artifacts.
coverage/
.nyc_output/
